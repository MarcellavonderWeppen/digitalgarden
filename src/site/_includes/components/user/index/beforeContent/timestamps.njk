{# Marcella: Änderung für Timestamps auch auf Homepage #}

{%- if created or updated -%}
<div class="timestamps">
  {%- if created -%}
  <div><i data-lucide="calendar-plus"></i> <span class="human-date" data-date="{{created}}"></span></div>
  {%- endif -%}
  {%- if updated -%}
  <div><i data-lucide="calendar-clock"></i> <span class="human-date" data-date="{{updated}}"></span></div>
  {%- endif -%}
</div>
<script src="https://fastly.jsdelivr.net/npm/luxon@3.2.1/build/global/luxon.min.js"></script>
<script defer>
  TIMESTAMP_FORMAT = "{{meta.timestampSettings.timestampFormat}}";
  document.querySelectorAll('.human-date').forEach(function (el) {
    var date = el.getAttribute('data-date') || el.innerText;
    var parsed_date = luxon.DateTime.fromISO(date);
    if (parsed_date.invalid != null) {
      parsed_date = luxon.DateTime.fromSQL(date);
    }
    if (parsed_date.invalid != null) {
      parsed_date = luxon.DateTime.fromHTML(date);
    }
    el.innerHTML = parsed_date.toFormat(TIMESTAMP_FORMAT);
  });
</script>
{%- endif -%}
